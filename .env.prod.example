# Copia este archivo a .env.prod y sustituye todos los valores CHANGE_ME.
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://mindflow_user:CHANGE_ME_POSTGRES_PASSWORD@db:5432/mindflow?connection_limit=10&pool_timeout=20
POSTGRES_DB=mindflow
POSTGRES_USER=mindflow_user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MINIMUM_32_CHARACTERS
AI_SERVICE_API_KEY=CHANGE_ME_IF_REQUIRED
FRONTEND_URL=https://CHANGE_ME_FRONTEND_DOMAIN
NEXT_PUBLIC_API_URL=http://backend:3001/api/v1
NEXT_PUBLIC_APP_URL=https://CHANGE_ME_FRONTEND_DOMAIN
AUTH_SECRET=CHANGE_ME_DIFFERENT_RANDOM_SECRET_MINIMUM_32_CHARACTERS
AUTH_DEBUG=false
